# Local Ollama daemon for free, on-device inference. Leave commented to use the
# default http://localhost:11434.
# OLLAMA_BASE_URL=http://localhost:11434

# GitHub OAuth — required to enable "Sign in with GitHub" in the GitHub panel.
# Register an OAuth app at https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Personal access token (classic, read:user + public_repo). Optional fallback
# used when no OAuth session is present; raises the API rate limit.
GITHUB_TOKEN=

# Firecrawl — powers the "Fetch JD" button that scrapes a job posting URL.
# Sign up at https://www.firecrawl.dev/. Optional.
FIRECRAWL_API_KEY=

# Cloud LLM provider API keys. Set the one(s) you want to use.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional: override the directory where LLM runs are appended as JSONL.
# Defaults to <project-root>/.runs/runs.jsonl
# CAREER_CONTEXT_RUNS_DIR=
